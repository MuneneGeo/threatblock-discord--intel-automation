      "parameters": {
        "jsCode": "// Advanced Cybersecurity Intelligence Newsletter Generator - n8n Function Node\n// Processes RSS security articles and builds a clean HTML digest for AI enrichment or direct sending\n\nlet newsItems = [];\n\ntry {\n  if ($input && $input.all().length > 0) {\n    const inputItems = $input.all();\n\n    if (inputItems.length === 1 && Array.isArray(inputItems[0].json)) {\n      newsItems = inputItems[0].json;\n    } else {\n      newsItems = inputItems.map(item => item.json);\n    }\n  } else if (typeof items !== 'undefined' && items.length > 0) {\n    if (items.length === 1 && Array.isArray(items[0].json)) {\n      newsItems = items[0].json;\n    } else {\n      newsItems = items.map(item => item.json);\n    }\n  }\n\n  console.log(`Loaded ${newsItems.length} raw news items`);\n} catch (error) {\n  console.log(`Input processing error: ${error.message}`);\n\n  return [\n    {\n      json: {\n        error: true,\n        subject: \"Cybersecurity Intelligence Digest Error\",\n        html: `<h1>Error Building Newsletter</h1><p>${error.message}</p>`\n      }\n    }\n  ];\n}\n\n// Generate date\nconst today = new Date();\n\nconst dateString = today.toLocaleDateString('en-US', {\n  weekday: 'long',\n  year: 'numeric',\n  month: 'long',\n  day: 'numeric'\n});\n\n// Keep only recent articles\nconst hoursToInclude = 12;\nconst cutoffTime = Date.now() - (hoursToInclude * 60 * 60 * 1000);\n\nlet filteredArticles = newsItems.filter(article => {\n  if (!article) return false;\n\n  const articleDate = article.isoDate\n    ? (typeof article.isoDate === 'number'\n      ? article.isoDate\n      : new Date(article.isoDate).getTime())\n    : 0;\n\n  return articleDate >= cutoffTime;\n});\n\nconsole.log(`Articles after time filtering: ${filteredArticles.length}`);\n\n// Remove duplicates by title or link\nconst seenTitles = new Set();\nconst seenLinks = new Set();\n\nfilteredArticles = filteredArticles.filter(article => {\n  const title = (article.title || '').trim().toLowerCase();\n  const link = (article.link || '').trim().toLowerCase();\n\n  if (!title && !link) return false;\n\n  if (seenTitles.has(title) || seenLinks.has(link)) {\n    return false;\n  }\n\n  seenTitles.add(title);\n  seenLinks.add(link);\n\n  return true;\n});\n\nconsole.log(`Articles after deduplication: ${filteredArticles.length}`);\n\n// Limit number of articles\nfilteredArticles = filteredArticles.slice(0, 30);\n\nconsole.log(`Articles after limit: ${filteredArticles.length}`);\n\n// Smart category mapping\nconst categories = {\n  \"Critical Threat Alerts\": [],\n  \"Malware & Ransomware\": [],\n  \"Data Breaches & Incident Response\": [],\n  \"Cloud Security\": [],\n  \"Fintech & Banking Threats\": [],\n  \"AI Security & Emerging Technology Risks\": [],\n  \"Identity & Access Management Threats\": [],\n  \"Vulnerability & Patch Alerts\": [],\n  \"Nation-State Threats & APT Activity\": [],\n  \"Security Tools, Detection & Defensive Best Practices\": [],\n  \"Other Security News\": []\n};\n\n// Keywords for categorization\nconst categoryKeywords = {\n  \"Critical Threat Alerts\": [\"critical\", \"actively exploited\", \"zero-day\", \"urgent\", \"emergency\"],\n  \"Malware & Ransomware\": [\"ransomware\", \"malware\", \"trojan\", \"loader\", \"botnet\", \"worm\"],\n  \"Data Breaches & Incident Response\": [\"breach\", \"leak\", \"incident\", \"compromise\", \"stolen\", \"data exposure\"],\n  \"Cloud Security\": [\"aws\", \"azure\", \"gcp\", \"cloud\", \"kubernetes\", \"docker\", \"iam\", \"api\", \"s3\", \"lambda\"],\n  \"Fintech & Banking Threats\": [\"bank\", \"payment\", \"fintech\", \"fraud\", \"swift\", \"mpesa\", \"sacco\", \"crypto\"],\n  \"AI Security & Emerging Technology Risks\": [\"ai\", \"llm\", \"machine learning\", \"deepfake\", \"chatgpt\", \"model\"],\n  \"Identity & Access Management Threats\": [\"identity\", \"authentication\", \"password\", \"mfa\", \"oauth\", \"access\"],\n  \"Vulnerability & Patch Alerts\": [\"vulnerability\", \"cve\", \"patch\", \"update\", \"exploit\"],\n  \"Nation-State Threats & APT Activity\": [\"apt\", \"china\", \"russia\", \"iran\", \"north korea\", \"state-sponsored\"],\n  \"Security Tools, Detection & Defensive Best Practices\": [\"defender\", \"siem\", \"edr\", \"xdr\", \"detection\", \"monitoring\"]\n};\n\n// Categorize articles\nfilteredArticles.forEach(article => {\n  const combinedText = `\n    ${(article.title || '')}\n    ${(article.contentSnippet || '')}\n    ${(article.content || '')}\n    ${(article.categories || '')}\n  `.toLowerCase();\n\n  let matched = false;\n\n  for (const [category, keywords] of Object.entries(categoryKeywords)) {\n    if (keywords.some(keyword => combinedText.includes(keyword))) {\n      categories[category].push(article);\n      matched = true;\n      break;\n    }\n  }\n\n  if (!matched) {\n    categories[\"Other Security News\"].push(article);\n  }\n});\n\n// Function to clean content\nfunction cleanContent(content) {\n  if (!content) return \"No summary available.\";\n\n  return content\n    .replace(/<[^>]*>/g, '')\n    .replace(/\\s+/g, ' ')\n    .trim()\n    .slice(0, 350);\n}\n\n// Generate HTML\nfunction generateNewsletterHTML() {\n  const styles = `\n    body {\n      font-family: Arial, sans-serif;\n      background-color: #f4f6f8;\n      color: #2c3e50;\n      max-width: 1000px;\n      margin: auto;\n      padding: 20px;\n    }\n    .header {\n      background: #111827;\n      color: white;\n      padding: 30px;\n      border-radius: 10px;\n      margin-bottom: 20px;\n    }\n    .header h1 {\n      margin: 0;\n      color: #ffffff;\n    }\n    .summary-box {\n      background: #ffffff;\n      border-left: 5px solid #dc2626;\n      padding: 15px;\n      margin-bottom: 25px;\n      border-radius: 8px;\n    }\n    h2 {\n      color: #dc2626;\n      border-bottom: 2px solid #e5e7eb;\n      padding-bottom: 8px;\n      margin-top: 40px;\n    }\n    .article {\n      background: #ffffff;\n      border-radius: 10px;\n      padding: 18px;\n      margin-bottom: 15px;\n      box-shadow: 0 2px 6px rgba(0,0,0,0.08);\n    }\n    .article h3 {\n      margin-top: 0;\n      color: #111827;\n    }\n    .article p {\n      margin: 8px 0;\n      color: #4b5563;\n    }\n    .article a {\n      color: #dc2626;\n      font-weight: bold;\n      text-decoration: none;\n    }\n    .article a:hover {\n      text-decoration: underline;\n    }\n    .meta {\n      font-size: 12px;\n      color: #6b7280;\n      margin-top: 10px;\n    }\n    .footer {\n      margin-top: 40px;\n      font-size: 13px;\n      color: #6b7280;\n      text-align: center;\n      border-top: 1px solid #d1d5db;\n      padding-top: 20px;\n    }\n  `;\n\n  let html = `\n  <!DOCTYPE html>\n  <html>\n  <head>\n    <meta charset=\"UTF-8\">\n    <title>Daily Cybersecurity Threat Briefing</title>\n    <style>${styles}</style>\n  </head>\n  <body>\n\n    <div class=\"header\">\n      <h1>Daily Cybersecurity Threat Briefing</h1>\n      <p>${dateString}</p>\n    </div>\n\n    <div class=\"summary-box\">\n      <strong>Digest Summary:</strong><br>\n      ${filteredArticles.length} curated cybersecurity articles from the last ${hoursToInclude} hours across trusted intelligence sources.\n    </div>\n  `;\n\n  Object.entries(categories).forEach(([category, articles]) => {\n    if (!articles.length) return;\n\n    html += `<h2>${category} (${articles.length})</h2>`;\n\n    articles.forEach(article => {\n      const formattedDate = article.isoDate\n        ? new Date(article.isoDate).toLocaleString('en-US', {\n            month: 'short',\n            day: 'numeric',\n            hour: 'numeric',\n            minute: '2-digit'\n          })\n        : 'Unknown date';\n\n      html += `\n        <div class=\"article\">\n          <h3>${article.title || 'Untitled Article'}</h3>\n          <p>${cleanContent(article.contentSnippet || article.content)}</p>\n          <a href=\"${article.link || '#'}\" target=\"_blank\">Read Full Article</a>\n          <div class=\"meta\">\n            Source: ${article.creator || article.source || 'Unknown'} |\n            Published: ${formattedDate}\n          </div>\n        </div>\n      `;\n    });\n  });\n\n  html += `\n    <div class=\"footer\">\n      <p><em>This report was automatically generated to help security teams understand the daily cyber threat landscape.</em></p>\n      <p>Think of this digest like your morning SOC standup — quick, actionable, and built to stop surprises before they become headlines.</p>\n    </div>\n  </body>\n  </html>\n  `;\n\n  return html;\n}\n\nconst newsletterHTML = generateNewsletterHTML();\n\nreturn [\n  {\n    json: {\n      subject: `Daily Cybersecurity Threat Briefing - ${dateString}`,\n      html: newsletterHTML,\n      articleCount: filteredArticles.length,\n      categoryCount: Object.keys(categories).filter(cat => categories[cat].length > 0).length\n    }\n  }\n];"
      },
