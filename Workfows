        "jsCode": "return items.map(item => {\n  const raw = String(item.json.output || '').trim();\n\n  let data = {\n    subject: 'Cybersecurity Threat Briefing',\n    html: ''\n  };\n\n  // Try JSON code block\n  const jsonMatch = raw.match(/```json\\s*([\\s\\S]*?)```/i);\n\n  // Try HTML code block\n  const htmlMatch = raw.match(/```html\\s*([\\s\\S]*?)```/i);\n\n  try {\n    // JSON inside ```json block\n    if (jsonMatch && jsonMatch[1]) {\n      const cleanJson = jsonMatch[1]\n        .trim()\n        .replace(/,\\s*([}\\]])/g, '$1');\n\n      const parsed = JSON.parse(cleanJson);\n\n      data = {\n        subject: parsed.subject || 'Cybersecurity Threat Briefing',\n        html: parsed.html || ''\n      };\n    }\n\n    // HTML inside ```html block\n    else if (htmlMatch && htmlMatch[1]) {\n      data.html = htmlMatch[1].trim();\n    }\n\n    // Raw HTML response\n    else if (\n      raw.startsWith('<h1') ||\n      raw.startsWith('<html') ||\n      raw.startsWith('<!DOCTYPE') ||\n      raw.startsWith('<div') ||\n      raw.startsWith('<p') ||\n      raw.startsWith('<ul')\n    ) {\n      data.html = raw;\n    }\n\n    // Raw JSON response\n    else if (raw.startsWith('{') || raw.startsWith('[')) {\n      const cleanRaw = raw.replace(/,\\s*([}\\]])/g, '$1');\n      const parsed = JSON.parse(cleanRaw);\n\n      data = {\n        subject: parsed.subject || 'Cybersecurity Threat Briefing',\n        html: parsed.html || ''\n      };\n    }\n\n    // Fallback: treat everything as plain HTML/text\n    else {\n      data.html = `<p>${raw}</p>`;\n    }\n  } catch (err) {\n    // Final fallback so workflow never crashes\n    data = {\n      subject: 'Cybersecurity Threat Briefing',\n      html: `<p>${raw}</p>`\n    };\n  }\n\n  const html = data.html || '';\n\n  const formattedText = html\n    .replace(/<h1>(.*?)<\\/h1>/gi, '\\n🔥 *$1*\\n')\n    .replace(/<h2>(.*?)<\\/h2>/gi, '\\n📌 *$1*\\n')\n    .replace(/<h3>(.*?)<\\/h3>/gi, '\\n➡️ *$1*\\n')\n    .replace(/<li>(.*?)<\\/li>/gis, '• $1\\n')\n    .replace(/<ul>|<\\/ul>|<ol>|<\\/ol>/gi, '')\n    .replace(/<strong>(.*?)<\\/strong>/gi, '*$1*')\n    .replace(/<b>(.*?)<\\/b>/gi, '*$1*')\n    .replace(/<em>(.*?)<\\/em>/gi, '_$1_')\n    .replace(/<p>(.*?)<\\/p>/gi, '$1\\n\\n')\n    .replace(/<br\\s*\\/?>/gi, '\\n')\n    .replace(/<a\\s+href=\"(.*?)\".*?>(.*?)<\\/a>/gi, '$2: $1')\n    .replace(/<[^>]+>/g, '')\n    .replace(/&nbsp;/g, ' ')\n    .replace(/&amp;/g, '&')\n    .replace(/&quot;/g, '\"')\n    .replace(/&#39;/g, \"'\")\n    .replace(/&lt;/g, '<')\n    .replace(/&gt;/g, '>')\n    .replace(/\\n{3,}/g, '\\n\\n')\n    .replace(/[ \\t]{2,}/g, ' ')\n    .trim();\n\n  const subject = data.subject || 'Cybersecurity Threat Briefing';\n\n  return {\n    json: {\n      subject,\n      discord_message: `🔒 *${subject}*\\n\\n${formattedText.substring(0, 1900)}`,\n      whatsapp_message: `🔒 *${subject}*\\n\\n${formattedText.substring(0, 3500)}`,\n      full_text: formattedText,\n      raw_html: html,\n      raw_response: raw\n    }\n  };\n});"
